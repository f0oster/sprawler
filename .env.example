# =============================================================================
# Sprawler Configuration
# =============================================================================
# Copy this file to .env.local and fill in your tenant-specific values.
# .env.local is gitignored and will not be committed.

# SharePoint admin user account (global admin or SharePoint admin)
SPRAWLER_SP_ADMIN_USER=admin@yourtenant.onmicrosoft.com

# Estimated total number of OneDrive sites in the tenant.
# Optional setting, used only for ETA and progress percentage in reports.
# If not set, ETA and percentage are omitted from report summaries.
# SPRAWLER_OD_EXPECTED_SITES=300000

# Estimated total number of SharePoint sites in the tenant.
# Optional setting, used only for ETA and progress percentage in reports.
# If not set, ETA and percentage are omitted from report summaries.
# SPRAWLER_SP_EXPECTED_SITES=200000

# =============================================================================
# Authentication
# =============================================================================

# SharePoint tenant admin site URL
SPRAWLER_SP_TENANT_ADMIN_SITE=https://yourtenant-admin.sharepoint.com
# Microsoft Entra (Azure AD) tenant ID
SPRAWLER_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# Microsoft Entra application (client) ID
SPRAWLER_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Path to the certificate file (.pfx or .p12)
SPRAWLER_ENTRA_CERT_PATH=./certificates/your-cert.pfx

# =============================================================================
# Logging
# =============================================================================
# Controls console log verbosity. Not prefixed with SPRAWLER_ as LOG_LEVEL
# is a common standard.
# Levels: TRACE, DEBUG, INFO, WARN, ERROR
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# Database Configuration
# =============================================================================
# Sprawler stores extracted data in a local SQLite database. These settings
# control the database location and write behaviour.

# Database type (currently, only SQLite is supported)
# Default: sqlite
SPRAWLER_DB_TYPE=sqlite

# Path where the database file will be stored
# Default: ./data
SPRAWLER_DB_PATH=./data

# Name of the database file
# Default: spo.db
SPRAWLER_DB_NAME=spo.db


# Recreate the database on each run.
# When true (default), the database is dropped and recreated at startup,
# giving a clean export every time.
#
# Default: true
SPRAWLER_DB_RECREATE=true

# Database write batching

# How many records to group for each database write.
#
# Default: 500
SPRAWLER_DB_BATCH_SIZE=500

# Maximum time between database writes, even if a full batch hasn't
# been collected yet.
#
# Format: duration (e.g., 5s, 2m)
# Default: 5s
# Recommended range: 2s–30s
SPRAWLER_DB_FLUSH_INTERVAL=5s

# How many unsaved records can be queued for writing before processing
# pauses. Higher values use more memory but let processing run further
# ahead of database writes.
#
# Default: 8000
# Recommended range: 2000–20000
SPRAWLER_DB_QUEUE_CAPACITY=8000

# Save details of failed database writes to a log file for troubleshooting.
#
# When enabled, debug information for failed database writes is written to
# the file specified by SPRAWLER_DB_FAILURE_LOG_PATH.
# Each entry includes the timestamp, batch size, the items, and any errors.
#
# Default: true
SPRAWLER_DB_ENABLE_FAILURE_LOG=true

# Path for the failed writes log file.
#
# Default: ./failed_writes.ndjson
SPRAWLER_DB_FAILURE_LOG_PATH=./failed_writes.ndjson

# SQLite lock wait timeout in milliseconds.
# How long to wait for a database lock before failing.
#
# Default: 5000
SPRAWLER_DB_BUSY_TIMEOUT=5000

# SQLite page cache size. Negative values specify size in KB.
# -262144 = ~256MB cache.
#
# Default: -262144
SPRAWLER_DB_CACHE_SIZE=-262144

# =============================================================================
# Transport / Retry
# =============================================================================
# Controls HTTP transport behaviour including retries for transient network
# errors and the default backoff when SharePoint throttles without a
# Retry-After header.

# Max transport-level retries for transient network errors (connection reset,
# EOF). These retries happen below gosip's HTTP-status retry layer and only
# apply to idempotent (GET) requests.
#
# Default: 3
SPRAWLER_TRANSPORT_MAX_RETRIES=3

# Comma-separated backoff durations for each transport retry attempt.
# Length should match SPRAWLER_TRANSPORT_MAX_RETRIES.
#
# Default: 5s,10s,30s
SPRAWLER_TRANSPORT_RETRY_BACKOFFS=5s,10s,30s

# Default pause duration when a 429/503 response does not include a
# Retry-After header. All workers are gated behind this pause.
#
# Default: 1m
SPRAWLER_TRANSPORT_THROTTLE_PAUSE=1m

# Per-status-code retry limits for gosip's HTTP retry layer.
# These control how many times gosip retries a request that returns the
# given status code before giving up.
SPRAWLER_TRANSPORT_RETRY_500=5
SPRAWLER_TRANSPORT_RETRY_503=10
SPRAWLER_TRANSPORT_RETRY_504=10
SPRAWLER_TRANSPORT_RETRY_429=10
SPRAWLER_TRANSPORT_RETRY_401=5

# =============================================================================
# Throttle Recovery
# =============================================================================

# How long to wait before restoring workers after SharePoint rate-limiting.
#
# When SharePoint returns rate-limit errors (HTTP 429), Sprawler halves the
# active worker count immediately and monitors for further throttling.
#
# If no further throttling is detected, Sprawler restores one additional worker
# per cooldown interval until the original worker count is reached.
#
# Default: 1m | Format: duration e.g., 30s, 1m, 2m
# Recommended range: 30s-10m
SPRAWLER_THROTTLE_RECOVERY_COOLDOWN=1m

# How often the throttle scaler checks for backpressure signals (429s,
# connection resets). Lower values respond to throttling faster but add
# overhead.
#
# Default: 10s
SPRAWLER_THROTTLE_CHECK_INTERVAL=10s

# =============================================================================
# SharePoint Configuration
# =============================================================================
# Controls how Sprawler enumerates SharePoint sites and collects users,
# groups, and group members from each site.

# Comma-separated list of SharePoint site templates to skip during
# enumeration. Sites matching these templates are filtered out before
# processing. Tenant root sites are always skipped regardless of this
# setting.
#
# Default: TEAMCHANNEL#0,TEAMCHANNEL#1,APPCATALOG#0,REDIRECTSITE#0
SPRAWLER_SP_SKIP_TEMPLATES=TEAMCHANNEL#0,TEAMCHANNEL#1,APPCATALOG#0,REDIRECTSITE#0

# Number of sites returned per page from the tenant admin REST API
# SharePoint caps this at 5000. Smaller page sizes reduce memory usage during
# the extraction, but increase the number of API calls needed to enumerate the tenant
# site list.
#
# Default: 5000
# Recommended value: 5000
SPRAWLER_SP_PAGE_SIZE=5000

# Concurrent workers fetching users from individual sites.
# Each worker fetches users from one site at a time. More workers increase
# throughput but also increase the likelihood of throttling. Sprawler
# automatically reduces this at runtime if throttled.
#
# Default: 6 | Recommended: 4-8
SPRAWLER_SP_USER_WORKERS=6

# Concurrent workers fetching groups from individual sites.
# Each worker fetches groups from one site at a time. Group requests are
# heavier than user requests and more likely to trigger throttling, so
# fewer group workers than user workers is recommended.
# Not used if SPRAWLER_SP_PROCESS_GROUPS is false.
#
# Default: 4 | Recommended: 2-6
SPRAWLER_SP_GROUP_WORKERS=4

# Enable enumeration of SharePoint site groups.
# When false (default), group lookups are skipped and only the site user
# list is collected per site. Since groups can be inferred from the user
# list, explicit group enumeration is usually only needed when you also
# want to collect group membership details.
# Default: false
SPRAWLER_SP_PROCESS_GROUPS=false

# Enable enumeration of members within each site group
# Requires SPRAWLER_SP_PROCESS_GROUPS=true. When false, groups are
# collected but their individual members are not expanded. Member
# enumeration makes a separate API call per group and is the slowest
# part of the extraction on large tenants.
# Default: false
SPRAWLER_SP_PROCESS_GROUP_MEMBERS=false

# Timeout for fetching users from a single SharePoint site.
#
# Applied per-site. If the request takes longer than this, it is cancelled
# and the site is marked as failed in the outcomes summary. Large sites
# (10k+ users) or sites with many external sharing links tend to be the
# slowest.
#
# Default: 10m
# Recommended range: 30s–10m
SPRAWLER_SP_USER_FETCH_TIMEOUT=10m

# Timeout for fetching groups from a single SharePoint site.
#
# Applied per-site. If the request is not completed within this window,
# it is cancelled and the site is marked as failed. Group lists are
# typically smaller than user lists, so a shorter timeout is usually
# sufficient.
#
# Default: 10m
# Recommended range: 15s–10m
SPRAWLER_SP_GROUP_FETCH_TIMEOUT=10m

# Timeout for enumerating members of a single group.
#
# Applied per-group, not per-site. Each group's membership is fetched
# independently. Groups with many nested members (e.g., large AD security
# groups synced to SharePoint) or deeply nested group hierarchies may need
# a higher value.
#
# Default: 10m
# Recommended range: 10s–10m
SPRAWLER_SP_MEMBER_FETCH_TIMEOUT=10m

# How often to log a progress summary during SharePoint processing.
#
# Each report includes: sites processed and in-flight, entity counts
# (users, groups, members), skip reasons, active worker counts, processing
# rate (sites/sec), estimated time remaining, and API stats (total requests,
# errors, throttle count).
#
# Default: 1m
# Recommended range: 10s–5m
SPRAWLER_SP_PROGRESS_INTERVAL=1m

# =============================================================================
# OneDrive Configuration
# =============================================================================
# Controls OneDrive for Business (personal site) enumeration and
# processing. Sites are queued as they're discovered and picked up by
# workers that (1) fetch each site's user list and (2) look up the
# matching user profile.

# Size of the discovery queue between site discovery and processing workers.
#
# Sites are queued as they're discovered and picked up by workers for
# processing. The buffer absorbs bursts when discovery is faster than
# processing. When full, discovery pauses until workers free up capacity.
#
# Default: 500
# Recommended range: 200–1000
SPRAWLER_OD_CSOM_BUFFER_SIZE=500

# Concurrent workers processing discovered OneDrive sites.
#
# Each worker picks up a discovered site and performs two operations:
# fetching the site's user list and looking up the matching user profile.
# Workers run in parallel against different sites.
#
# Default: 6
# Recommended range: 4–10
SPRAWLER_OD_USER_WORKERS=6

# Timeout for fetching users from a single OneDrive personal site.
#
# Applied per-site. If the request is not completed within this window, it
# is cancelled and the site is marked as failed. OneDrive personal sites
# typically have small user lists, so timeouts here usually indicate
# network issues rather than data volume.
#
# Default: 10m
# Recommended range: 30s–10m
SPRAWLER_OD_USER_FETCH_TIMEOUT=10m

# Timeout for a single user profile lookup.
#
# Each OneDrive site triggers a profile lookup to fetch the owner's metadata
# (display name, department, manager, etc.). Profile lookups can be slow on
# large tenants under heavy load because the profile service is shared
# infrastructure.
#
# Default: 10m
# Recommended range: 15s–5m
SPRAWLER_OD_PROFILE_FETCH_TIMEOUT=10m

# How often to log a progress summary during OneDrive processing.
#
# Each report includes: sites discovered and processed, entity counts,
# active worker counts, processing rate (sites/sec), estimated time
# remaining, and API stats (total requests, errors, throttle count).
#
# Default: 1m
# Recommended range: 10s–5m
SPRAWLER_OD_PROGRESS_INTERVAL=1m

# =============================================================================
# Debug Configuration
# =============================================================================
# Settings to cap processing for quick test runs. Set to 0 for no limit.

# Maximum number of site pages to process (0 = unlimited)
# Useful for quick smoke tests. A value of 1-10 processes just a few
# pages of sites before stopping.
# Default: 0
SPRAWLER_DEBUG_MAX_PAGES=0

# Maximum number of OneDrive sites to process (0 = unlimited)
# Default: 0
SPRAWLER_DEBUG_MAX_ONEDRIVE_SITES=0

# For performance tuning guidance, see docs/performance-tuning.md
